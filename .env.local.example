# Copie ce fichier en .env.local et remplis les valeurs.

# Mot de passe pour accéder à /admin (obligatoire).
ADMIN_PASSWORD=change-moi

# Optionnel : si renseignés, l'admin commit les nouveaux projets/images
# directement dans ce dépôt GitHub (persiste même après un déploiement Vercel).
# Sans ces variables, l'admin écrit en local sur le disque (utile en dev uniquement).
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
